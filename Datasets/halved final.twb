      <aliases enabled='yes' />
      <column caption='Total revenue' datatype='real' name='[Calculation_1200993366835200]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Yield(Tons)] * [Price_per_Ton])' />
      </column>
      <column caption='Yield per Hectare' datatype='real' name='[Calculation_1200993366941697]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Yield(Tons)]) / SUM([Area(Hectare)])' />
      </column>
      <column caption='Avg Delivery Time' datatype='real' name='[Calculation_1200993367064579]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([DeliveryTime(days)])' />
      </column>
      <column caption='Avg Temperature' datatype='real' name='[Calculation_1200993367179268]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Temperature])' />
      </column>
      <column caption='Total Rainfall' datatype='real' name='[Calculation_1200993367244805]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Rainfall])' />
      </column>
      <column caption='Fertilizer Efficiency' datatype='real' name='[Calculation_1200993367298054]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Yield(Tons)]) / SUM([Quantity(kg)])' />
      </column>
      <column caption='Storage Utilization' datatype='real' name='[Calculation_1200993367363591]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Capacity(Tons)]) / COUNT([StorageID])' />
